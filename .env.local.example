# Copy this file to .env.local and fill in real values.
# .env.local is gitignored; never commit real credentials.

# Cloudinary — used by /photography to fetch and render the gallery.
# Get these from https://console.cloudinary.com (Dashboard → API Keys).

# Public — exposed to the client, used by the next/image loader.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name

# Server-only — used by the Admin API request to list photos.
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Optional — Cloudinary folder to fetch from. Defaults to "portfolio".
# CLOUDINARY_FOLDER=portfolio
